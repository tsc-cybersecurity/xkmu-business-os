{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "ignoreCommand": "if git log -1 --format='%an' | grep -q 'github-actions\\[bot\\]'; then exit 0; else exit 1; fi",
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/v1/blog/posts/generate/*.ts": {
      "maxDuration": 120
    },
    "src/app/api/v1/blog/posts/*/seo/generate/*.ts": {
      "maxDuration": 120
    },
    "src/app/api/v1/cms/pages/*/seo/generate/*.ts": {
      "maxDuration": 120
    },
    "src/app/api/v1/companies/*/research/*.ts": {
      "maxDuration": 120
    }
  },
  "crons": [],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version, X-Api-Key"
        }
      ]
    }
  ]
}
