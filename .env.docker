# ============================================
# xKMU Business OS - Lokale Docker-Konfiguration
# ============================================
# Kopiere diese Datei nach .env bevor du startest:
#   cp .env.docker .env
#
# Dann starten mit:
#   docker compose -f docker-compose.local.yml up -d --build
# ============================================

# Datenbank-Passwort
DB_PASSWORD=xkmu_local_2024

# JWT Secret (min 32 Zeichen - in Produktion unbedingt ändern!)
JWT_SECRET=local_dev_jwt_secret_min_32_chars_change_me

# App-URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Ports (optional - Defaults unten)
# ============================================
# APP_PORT=3000
# DB_PORT=5432
# REDIS_PORT=6379
# REDIS_PASSWORD=xkmu_local_2024

# ============================================
# AI Provider Keys (optional)
# ============================================
# GOOGLE_AI_API_KEY=
# OPENAI_API_KEY=

# ============================================
# Backup (optional)
# ============================================
# Anzahl der Pre-Migration-Backups die behalten werden (Default: 10)
# BACKUP_KEEP=10

# ============================================
# E-Mail / SMTP (optional)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
