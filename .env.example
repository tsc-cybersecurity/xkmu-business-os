# ===========================================
# xKMU Business OS - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# For Vercel: Add these in Project Settings > Environment Variables

# ===========================================
# REQUIRED - Database
# ===========================================
# PostgreSQL connection string
# For Vercel Postgres: Automatically set when you add Vercel Postgres
# For Neon: postgresql://user:password@ep-xxx.region.neon.tech/dbname?sslmode=require
# For Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
# For local Docker: postgresql://xkmu:password@localhost:5432/xkmu
DATABASE_URL=

# Database SSL mode
# "require" = SSL required (default for Vercel/Neon/Supabase cloud databases)
# "false"   = No SSL (use for Docker/Coolify with local PostgreSQL)
# Leave empty for auto-detection (production=require, Docker/Coolify=false, dev=false)
# DATABASE_SSL=

# ===========================================
# REQUIRED - Authentication
# ===========================================
# JWT secret for session tokens (min 32 characters, use a strong random string)
# Generate with: openssl rand -base64 32
JWT_SECRET=

# ===========================================
# RECOMMENDED - AI Providers (at least one required for AI features)
# ===========================================

# Google Gemini (Recommended - cost-effective)
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# OpenAI (Alternative)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ===========================================
# OPTIONAL - Local AI (not available on Vercel)
# ===========================================
# Ollama - Only for local development or self-hosted environments
# Leave empty for Vercel deployment
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma3

# ===========================================
# OPTIONAL - Email (SMTP)
# ===========================================
# For Gmail: Use App Password (not regular password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ===========================================
# OPTIONAL - Application Settings
# ===========================================
# Public URL of your application
# For Vercel: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment (automatically set by Vercel)
NODE_ENV=development

# ===========================================
# OPTIONAL - Redis (for session caching)
# ===========================================
# Leave empty to use in-memory sessions
# REDIS_URL=redis://localhost:6379

# ===========================================
# VERCEL DEPLOYMENT NOTES
# ===========================================
# 1. Add DATABASE_URL from your PostgreSQL provider (Vercel Postgres, Neon, etc.)
# 2. Add JWT_SECRET (generate a strong random string)
# 3. Add at least one AI provider key (GOOGLE_AI_API_KEY recommended)
# 4. Do NOT add OLLAMA_* variables (not supported on serverless)
# 5. SMTP settings are optional (can be configured later)

# ===========================================
# COOLIFY / DOCKER DEPLOYMENT NOTES
# ===========================================
# 1. Use docker-compose.coolify.yml (DATABASE_URL is auto-configured)
# 2. Set DB_PASSWORD and JWT_SECRET in Coolify environment variables
# 3. Set NEXT_PUBLIC_APP_URL to your public domain (e.g. https://app.example.com)
# 4. DATABASE_SSL is set to "false" automatically (local PostgreSQL, no SSL needed)
# 5. Schema is auto-synced via drizzle-kit push on container start
# 6. Default admin account: admin@example.com / admin123 (change after first login!)
