# ===========================================
# xKMU Business OS - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED - Database
# ===========================================
# PostgreSQL connection string
# Docker: postgresql://xkmu:password@localhost:5432/xkmu
DATABASE_URL=

# Database SSL mode
# "require" = SSL required (for external databases)
# "false"   = No SSL (default for Docker with local PostgreSQL)
# DATABASE_SSL=

# ===========================================
# REQUIRED - Authentication
# ===========================================
# JWT secret for session tokens (min 32 characters, use a strong random string)
# Generate with: openssl rand -base64 32
JWT_SECRET=

# HMAC secret for cancel/reschedule appointment tokens (min 32 characters)
# Tokens are embedded in customer mails — rotating this secret invalidates all
# outstanding cancel/reschedule links (acceptable since they expire at the
# appointment start time anyway).
# Generate with: openssl rand -hex 32
APPOINTMENT_TOKEN_SECRET=

# ===========================================
# RECOMMENDED - AI Providers (at least one required for AI features)
# ===========================================

# Google Gemini (Recommended - cost-effective)
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# OpenAI (Alternative)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ===========================================
# OPTIONAL - Local AI (Ollama)
# ===========================================
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma3

# ===========================================
# OPTIONAL - Email (SMTP)
# ===========================================
# For Gmail: Use App Password (not regular password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ===========================================
# OPTIONAL - Backup
# ===========================================
# Number of pre-migration backups to keep (default: 10)
# BACKUP_KEEP=10

# ===========================================
# OPTIONAL - Social Media (Meta OAuth: Facebook Page + Instagram Direct)
# ===========================================
# Create a Meta App at https://developers.facebook.com/apps/
#
# Facebook Page (use case: "Alles auf deiner Seite verwalten")
# Required scopes: pages_show_list, pages_manage_posts, pages_read_engagement
# META_APP_ID=
# META_APP_SECRET=
# META_OAUTH_REDIRECT_URI=https://your-domain.example/api/social/meta/oauth/callback
#
# Instagram Direct (use case: "Messaging und Content auf Instagram verwalten")
# Required scopes: instagram_business_basic, instagram_business_content_publish
# IG-Sub-App-Credentials (separate from Facebook App ID/Secret) — see Instagram API Setup tab
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
# INSTAGRAM_OAUTH_REDIRECT_URI=https://your-domain.example/api/social/instagram/oauth/callback
#
# X (Twitter) — OAuth 2.0 with PKCE
# Required scopes: tweet.read, tweet.write, users.read, offline.access
# Free Tier reicht fuer <500 Tweets/Monat (text-only — Bilder sind nicht im Free Tier)
# X-App-Credentials aus https://developer.x.com/en/portal/dashboard
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# X_OAUTH_REDIRECT_URI=https://your-domain.example/api/social/x/oauth/callback
#
# LinkedIn — OAuth 2.0 + OIDC userinfo
# Required products im Developer-Portal: "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn"
# Required scopes: openid, profile, email, w_member_social
# Tokens leben 60 Tage; LinkedIn liefert refresh_token nur bei Marketing-API-Apps
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_OAUTH_REDIRECT_URI=https://your-domain.example/api/social/linkedin/oauth/callback

# ===========================================
# OPTIONAL - Application Settings
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ===========================================
# OPTIONAL - Redis (for session caching)
# ===========================================
# Leave empty to use in-memory sessions
# REDIS_URL=redis://:your_redis_password@localhost:6379
# REDIS_PASSWORD=your_redis_password

# ===========================================
# DOCKER LOCAL (docker-compose.local.yml)
# ===========================================
# 1. Copy this file to .env
# 2. Fill in the REQUIRED values below
# 3. Start: docker compose -f docker-compose.local.yml up -d --build
#
# REQUIRED for Docker:
DB_PASSWORD=              # PostgreSQL password (use a strong random string)
# JWT_SECRET=             # Already defined above - use a strong random string (min 32 chars)
REDIS_PASSWORD=           # Redis password (use a strong random string)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=         # pgAdmin login password (use a strong password, NOT admin123)
#
# OPTIONAL Docker ports:
# APP_PORT=3000
# DB_PORT=5432
#
# Generate strong passwords with: openssl rand -base64 32
#
# OPTIONAL: Override default admin user (set before first start)
# SEED_ADMIN_EMAIL=your-secure-email@domain.de
# SEED_ADMIN_PASSWORD=your-secure-password


# ===========================================
# COOLIFY (docker-compose.coolify.yml)
# ===========================================
# 1. Set DB_PASSWORD and JWT_SECRET in Coolify environment variables
# 2. Set NEXT_PUBLIC_APP_URL to your public domain (e.g. https://app.example.com)
# 3. DATABASE_SSL is set to "false" automatically (local PostgreSQL, no SSL needed)
# 4. Schema is auto-synced via drizzle-kit push on container start
# 5. Default admin account: admin@example.com / admin123 (change after first login!)
